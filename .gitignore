# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
logs/
# data/ — ignore runtime contents but track agent config
data/*
!data/agents/
!data/agent-knowledge/
!data/skill-catalog/
!data/trust-policy.yaml
!data/trust.yaml
# Crystallized skills are per-install runtime state
data/agents/*/skills/crystallized/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/main/
!groups/global/
!groups/telegram_claire/
groups/main/*
groups/global/*
groups/telegram_claire/*
!groups/main/CLAUDE.md
!groups/global/CLAUDE.md
!groups/global/state/
!groups/global/state/**
# Re-ignore state files that are local-only, auto-generated, or sensitive:
# - current.md: auto-rendered daily; previously slipped into git with PHI risk
# - followups.md: email-derived, contains counterparty PII; managed by
#   email-ingest.py and rebuilt on each ingest
# - bugs.md: local personal bug inbox, not a templated baseline
# - *.archived-*: superseded by the live tasks table in store/messages.db
groups/global/state/current.md
groups/global/state/followups.md
groups/global/state/bugs.md
groups/global/state/*.archived-*.md
groups/global/state/*-report.md
!groups/telegram_claire/CLAUDE.md
!groups/telegram_claire/memory_guardian/
groups/telegram_claire/memory_guardian/**/__pycache__/
# Secrets
*.keys.json
.env

# Worktrees
.worktrees/

# Runtime and generated sync artifacts
scripts/sync/__pycache__/
scripts/sync/*.pyc
scripts/sync/*.log
scripts/sync/gmail-sync-state.json
scripts/sync/gmail-sync-latest.json
scripts/paperpile-wiki/pipeline.log
scripts/state/*.json

# Swarm membership audit run-state (regenerated daily by scheduled task)
data/agents/swarm-membership-audit.json
data/agents/swarm-membership-audit-diffs.json
groups/telegram_claire/state/swarm-audit.md

# Note: groups/global/state/current.md is auto-rendered by scheduled task
# task-1774027787743-upd8cur as a view of the live tasks table in
# store/messages.db. Kept untracked deliberately — historically slipped
# into git (forced-add) and required PHI redaction in commit 511cff7.
# Now ignored explicitly by the rule in the groups/global/state/ block above.

# Skill output and runtime state
graphify-out/
.remember/
.claude/scheduled_tasks.lock

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

# ByteRover local context cache
.brv/

# Local retro/context cache (per-machine snapshots from /retro skill)
.context/

agents-sdk-docs

# Python venvs
scripts/pageindex/venv/
scripts/paperpile-wiki/venv/
scripts/markitdown/venv/
.claude/worktrees/
**/__pycache__/

# Defense-in-depth: never track CLAUDE.md files inside cloned upstream
# repos under groups/*/knowledge-base/ (e.g. agent-lightning ships its own
# CLAUDE.md). The real concern is Claude Code's parent-directory auto-
# discovery picking up the wrong file — that's not solved by .gitignore,
# but this rule makes sure the stray file can't accidentally get force-added
# even if groups/* is ever opened up.
groups/*/knowledge-base/**/CLAUDE.md
