{
  "name": "nanoclaw",
  "version": "1.2.50",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "bun dist/index.js",
    "dev": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "bun setup/index.ts",
    "auth": "bun src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "setup:pageindex": "cd scripts/pageindex && python3 -m venv venv && venv/bin/pip install -r requirements.txt"
  },
  "dependencies": {
    "@onecli-sh/sdk": "^0.2.0",
    "@slack/bolt": "^4.3.0",
    "@slack/types": "^2.15.0",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "grammy": "^1.39.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.10.0",
    "@types/sharp": "^0.32.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "bun": ">=1.2"
  }
}
