{
  "name": "cockpit-pwa",
  "version": "0.1.0",
  "private": true,
  "description": "Read-only PWA for the NanoClaw web cockpit. Renders snapshot.json + vault pages from R2 via the cockpit-worker.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:check": "vite build && node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "preact": "^10.27.2",
    "markdown-it": "^14.1.0",
    "highlight.js": "^11.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@testing-library/preact": "^3.2.4",
    "@types/markdown-it": "^14.1.2",
    "happy-dom": "^20.0.2",
    "typescript": "^5.6.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
